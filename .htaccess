Options -Indexes
DirectoryIndex index-direct.php
RewriteEngine On

# Onaylanan Vitlo kartını yeni premium WebP çıktısına yönlendir.
RewriteRule ^assets/portals/vitlo\.svg$ vitlo-image.php [L,QSA]

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^ index-direct.php [L,QSA]

<IfModule mod_deflate.c>
AddOutputFilterByType DEFLATE text/html text/css application/javascript image/svg+xml
</IfModule>
<IfModule mod_headers.c>
<FilesMatch "\.(css|js|svg|webp)$">
Header set Cache-Control "no-cache, no-store, must-revalidate"
Header set Pragma "no-cache"
Header set Expires "0"
</FilesMatch>
</IfModule>
